pipeline {
    agent any

    environment {
        DOCKER_USER = "dharaniprasads"
    }

    stages {

        stage('Clone Repo') {
            steps {
                git 'https://github.com/dharani070707/CICD_Paraphase_Semantic_Analysis.git'
            }
        }

        stage('Start Backend for Testing') {
            steps {
                sh '''
                docker build -t temp-backend backend/
                docker run -d -p 8000:8000 --name test-backend temp-backend

                # Wait for backend to be ready (max ~30s)
                for i in {1..30}; do
                  curl -sf http://localhost:8000/docs >/dev/null && break
                  sleep 1
                done
                '''
            }
        }

        stage('Run test50') {
            steps {
                sh '''
                python3 -m venv venv

                venv/bin/pip install --upgrade pip
                venv/bin/pip install -r backend/requirements.txt
                venv/bin/pip install requests

                # Debug check (optional)
                venv/bin/python -c "import requests; print('requests OK')"

                venv/bin/python tests/test50.py | tee result.txt
                '''
            }
        }

        stage('Stop Test Backend') {
            steps {
                sh '''
                docker stop test-backend || true
                docker rm test-backend || true
                '''
            }
        }

        stage('Check Pass Percentage') {
            steps {
                script {

                    def resultLine = sh(
                        script: "grep 'Final Result' result.txt || true",
                        returnStdout: true
                    ).trim()

                    if (!resultLine) {
                        error "Test execution failed OR no result found"
                    }

                    def percent = sh(
                        script: '''
                        grep 'Final Result' result.txt | awk -F'[()]' '{print $2}' | sed 's/%//'
                        ''',
                        returnStdout: true
                    ).trim()

                    def percentage = percent.toFloat()
                    echo "Pass Percentage: ${percentage}%"

                    if (percentage < 60) {
                        error "Less than 60% passed. Stopping pipeline."
                    }
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                sh '''
                docker build -t $DOCKER_USER/semantic-backend:latest backend/
                docker build -t $DOCKER_USER/semantic-frontend:latest frontend/
                '''
            }
        }

        stage('Push to DockerHub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'DockerHubCred',
                    usernameVariable: 'USERNAME',
                    passwordVariable: 'PASSWORD'
                )]) {
                    sh '''
                    echo $PASSWORD | docker login -u $USERNAME --password-stdin
                    docker push $DOCKER_USER/semantic-backend:latest
                    docker push $DOCKER_USER/semantic-frontend:latest
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                docker compose down
                docker compose up -d
                '''
            }
        }
    }

    post {
        always {
            sh '''
            docker stop test-backend || true
            docker rm test-backend || true
            '''
        }
    }
}
