pipeline {
    agent any

    environment {
        DOCKER_USER = "dharaniprasads"
    }

    stages {

        stage('Clone Repo') {
            steps {
                git branch: 'main', url: 'https://github.com/dharani070707/CICD_Paraphase_Semantic_Analysis.git'
            }
        }

        stage('Start Backend for Testing') {
            steps {
                sh '''
                docker build -t temp-backend backend/
		docker run -d -p 8000:8000 -v $(pwd)/backend/models:/app/models --name test-backend temp-backend


                echo "Initial logs:"
                sleep 5
                docker logs test-backend

                echo "Waiting for backend..."

                for i in {1..60}; do
                  if curl -sf http://localhost:8000/analyze >/dev/null; then
                    echo "Backend is UP"
                    break
                  fi
                  echo "Waiting... ($i)"
                  sleep 2
                done

                curl -f http://localhost:8000/analyze || (echo "Backend failed" && docker logs test-backend && exit 1)
                '''
            }
        }

        stage('Run test50') {
            steps {
                sh '''
                python3 -m venv venv
                . venv/bin/activate

                pip install --upgrade pip
                pip install -r backend/requirements.txt
                pip install requests

                echo "Checking backend again..."

                for i in {1..30}; do
                  if curl -sf http://localhost:8000/analyze >/dev/null; then
                    echo "Backend confirmed alive"
                    break
                  fi
                  sleep 2
                done

                python tests/test50.py | tee result.txt
                '''
            }
        }

        stage('Stop Test Backend') {
            steps {
                sh '''
                docker stop test-backend || true
                docker rm test-backend || true
                '''
            }
        }

        stage('Check Pass Percentage') {
            steps {
                script {
                    def percent = sh(
                        script: "grep 'Final Result' result.txt | cut -d'(' -f2 | cut -d'%' -f1",
                        returnStdout: true
                    ).trim()

                    if (!percent) {
                        error "Could not extract percentage from test output"
                    }

                    def percentage = percent.toFloat()
                    echo "Pass Percentage: ${percentage}%"

                    if (percentage < 60) {
                        error "Less than 60% passed. Stopping pipeline."
                    }
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                sh '''
                docker build -t $DOCKER_USER/semantic-backend:latest backend/
                docker build -t $DOCKER_USER/semantic-frontend:latest frontend/
                '''
            }
        }

        stage('Push to DockerHub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'DockerHubCred',
                    usernameVariable: 'USERNAME',
                    passwordVariable: 'PASSWORD'
                )]) {
                    sh '''
                    echo $PASSWORD | docker login -u $USERNAME --password-stdin

                    docker push $DOCKER_USER/semantic-backend:latest
                    docker push $DOCKER_USER/semantic-frontend:latest
                    '''
                }
            }
        }

        stage('Deploy') {
            steps {
                sh '''
                docker compose down
                docker compose up -d
                '''
            }
        }
    }

    post {
        always {
            sh '''
            docker stop test-backend || true
            docker rm test-backend || true
            '''
        }
    }
}
